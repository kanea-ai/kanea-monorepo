{
  "name": "www",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/www/app",
  "tags": ["scope:www", "type:app", "lang:ts"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/www",
        "command": "next dev --port 3001"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["production", "^production"],
      "outputs": ["{projectRoot}/.next"],
      "options": {
        "cwd": "apps/www",
        "command": "next build"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "apps/www",
        "command": "next start --port 3001"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default"],
      "options": {
        "cwd": "apps/www",
        "command": "next lint"
      }
    }
  }
}
