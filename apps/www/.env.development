# Loaded automatically by `next dev`. Personal overrides in
# apps/www/.env.development.local (gitignored, takes precedence).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Marketing CTAs deep-link into the SaaS app. Locally, that's the web-app
# dev server on :3000; in prod the build falls through to https://app.kanea.ai.
NEXT_PUBLIC_APP_URL=http://localhost:3000
