APP_NAME=kanea-api
ENVIRONMENT=development
VERSION=0.0.0

DATABASE_URL=postgresql+asyncpg://kanea:kanea@localhost:5432/kanea  # pragma: allowlist secret

# JWT signing secret. The same secret signs and verifies every JWT the
# platform issues — human workspace tokens, agent JWTs (scope='agent'),
# selection tokens, OAuth onboarding tickets. The Settings model
# REFUSES to boot in any non-development environment with the
# placeholder value (the unified _check_required_secrets_in_prod
# validator); provide a real one via Secret Manager / env var in
# staging + prod.
# Operational consequence: rotating or losing this secret invalidates
# every existing JWT atomically — humans get logged out, agents must
# re-exchange their API key. See README ops section.
JWT_SECRET=change-me-in-production  # pragma: allowlist secret
JWT_ALGORITHM=HS256
JWT_HUMAN_TTL_SECONDS=3600
JWT_AGENT_TTL_SECONDS=900

# Agent API-key HMAC pepper. The Settings model REFUSES to boot in any
# non-development environment with the placeholder value; provide a
# real one via Secret Manager / env var in staging + prod.
# Operational consequence: rotating or losing this pepper invalidates
# every existing agent API key (plaintext is never persisted, so
# rotation = mint new keys + revoke old). See docs ops section.
AGENT_API_KEY_PEPPER=change-me-in-production-agent-pepper  # pragma: allowlist secret

# `live` (prod) / `dev` (everything else).
AGENT_API_KEY_ENV_TAG=dev
