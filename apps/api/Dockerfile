# syntax=docker/dockerfile:1.7
# Multi-stage build for the Kanea FastAPI service.
# Built from the monorepo root: `docker build -f apps/api/Dockerfile .`
#
# We do NOT install Poetry in this image. Poetry 1.8.3 against this 2.1-format
# lockfile silently produced incomplete `poetry export` output (dropping
# email-validator and friends), which the buildx registry cache then locked in.
# Instead, `apps/api/requirements.txt` is committed and regenerated by hand
# whenever pyproject.toml/poetry.lock change. Build is now plain `pip install`.

# ---------- Builder ----------
FROM python:3.12-slim AS builder

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

RUN apt-get update \
 && apt-get install -y --no-install-recommends build-essential \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /build

COPY apps/api/requirements.txt ./requirements.txt

# Install into an isolated prefix so we can copy the result into the runtime stage.
RUN pip install --prefix=/install -r requirements.txt

# ---------- Runtime ----------
FROM python:3.12-slim AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8080

# Run as non-root.
RUN groupadd --system app && useradd --system --gid app --home-dir /app app

WORKDIR /app

COPY --from=builder /install /usr/local
COPY apps/api/app ./app
COPY apps/api/alembic ./alembic
COPY apps/api/alembic.ini ./alembic.ini

USER app

EXPOSE 8080

# Run Alembic migrations to head, then start the server. Idempotent —
# alembic compares against the alembic_version table and no-ops if already
# at head, so the cost on warm starts is one round-trip. Concurrent cold
# starts are safe: Alembic takes an advisory lock for the duration of
# `upgrade`, so other instances queue and then no-op.
#
# `exec` replaces the shell with uvicorn so PID 1 is the server itself —
# Cloud Run's SIGTERM for graceful shutdown reaches uvicorn directly,
# avoiding a stuck shell that would force a kill at the grace deadline.
#
# Shell form so $PORT (set by Cloud Run) is expanded at container start.
CMD alembic upgrade head && exec uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8080}
