{
  "name": "kanea-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run-many -t dev",
    "dev:db": "docker compose -f docker-compose.local.yml up -d",
    "dev:db:stop": "docker compose -f docker-compose.local.yml down",
    "dev:db:logs": "docker compose -f docker-compose.local.yml logs -f postgres",
    "dev:db:reset": "docker compose -f docker-compose.local.yml down -v",
    "dev:migrate": "cd apps/api && poetry run alembic upgrade head",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@nx/eslint": "20.3.0",
    "@nx/eslint-plugin": "20.3.0",
    "@nx/jest": "20.3.0",
    "@nx/next": "20.3.0",
    "@nx/workspace": "20.3.0",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.15",
    "nx": "20.3.0",
    "postcss": "8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "3.4.13",
    "typescript": "5.5.4"
  }
}
